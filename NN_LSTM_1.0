import os
import argparse
import numpy as np
import pandas as pd
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader
import matplotlib.pyplot as plt

# ==========================================
# 1. Reversible Instance Normalization (RevIN)
# ==========================================
class RevIN(nn.Module):
    def __init__(self, num_features: int, eps=1e-5, affine=True):
        """
        :param num_features: the number of features or channels
        :param eps: a value added for numerical stability
        :param affine: if True, RevIN has learnable affine parameters
        """
        super(RevIN, self).__init__()
        self.num_features = num_features
        self.eps = eps
        self.affine = affine
        if self.affine:
            self._init_params()

    def forward(self, x, mode:str):
        if mode == 'norm':
            self._get_statistics(x)
            x = self._normalize(x)
        elif mode == 'denorm':
            x = self._denormalize(x)
        else: raise NotImplementedError
        return x

    def _init_params(self):
        self.affine_weight = nn.Parameter(torch.ones(self.num_features))
        self.affine_bias = nn.Parameter(torch.zeros(self.num_features))

    def _get_statistics(self, x):
        dim2reduce = tuple(range(1, x.ndim-1))
        self.mean = torch.mean(x, dim=dim2reduce, keepdim=True).detach()
        self.stdev = torch.sqrt(torch.var(x, dim=dim2reduce, keepdim=True, unbiased=False) + self.eps).detach()

    def _normalize(self, x):
        x = x - self.mean
        x = x / self.stdev
        if self.affine:
            x = x * self.affine_weight
            x = x + self.affine_bias
        return x

    def _denormalize(self, x):
        if self.affine:
            x = x - self.affine_bias
            x = x / (self.affine_weight + self.eps*self.eps)
        x = x * self.stdev
        x = x + self.mean
        return x

# ==========================================
# 2. LSTM with RevIN and MC Dropout
# ==========================================
class LSTMWithRevIN(nn.Module):
    def __init__(self, num_features, hidden_size, num_layers, dropout_rate=0.2, target_idx=0):
        super(LSTMWithRevIN, self).__init__()
        self.revin_layer = RevIN(num_features, affine=True)
        self.lstm = nn.LSTM(
            input_size=num_features,
            hidden_size=hidden_size,
            num_layers=num_layers,
            batch_first=True,
            dropout=dropout_rate if num_layers > 1 else 0
        )
        self.dropout = nn.Dropout(dropout_rate)
        # We predict a single value per time step (the target)
        self.linear = nn.Linear(hidden_size, 1)
        self.target_idx = target_idx # Index of the target variable in the feature array

    def forward(self, x):
        # x shape: (batch_size, seq_len, num_features)
        
        # 1. Normalize with RevIN
        x_norm = self.revin_layer(x, 'norm')
        
        # 2. Extract specific stats for the target to denormalize later
        # We only want to denormalize the prediction, which corresponds to target_idx
        target_mean = self.revin_layer.mean[:, :, self.target_idx:self.target_idx+1]
        target_stdev = self.revin_layer.stdev[:, :, self.target_idx:self.target_idx+1]
        if self.revin_layer.affine:
            target_weight = self.revin_layer.affine_weight[self.target_idx:self.target_idx+1]
            target_bias = self.revin_layer.affine_bias[self.target_idx:self.target_idx+1]
        
        # 3. LSTM forward
        out_lstm, _ = self.lstm(x_norm)
        
        # 4. Apply MC Dropout & Linear map
        # We take the output of the last sequence step
        out_last = out_lstm[:, -1, :]
        out_drop = self.dropout(out_last)
        pred = self.linear(out_drop) # shape: (batch, 1)
        
        # Reshape to (batch, 1, 1) to match denorm constraints dimension-wise
        pred = pred.unsqueeze(1)
        
        # 5. Denormalize with RevIN manually for single target
        if self.revin_layer.affine:
            pred = pred - target_bias
            pred = pred / (target_weight + self.revin_layer.eps**2)
        pred = pred * target_stdev
        pred = pred + target_mean
        
        return pred.squeeze(1).squeeze(1) if pred.dim() > 2 else pred.squeeze(1) # shape: (batch)

# ==========================================
# 3. Data Processing & Dataset
# ==========================================
class TimeSeriesDataset(Dataset):
    def __init__(self, data, context_length, target_idx):
        """
        data: numpy array of shape (N, num_features)
        context_length: number of past steps to use
        target_idx: index of target feature
        """
        self.data = torch.FloatTensor(np.array(data, copy=True))
        self.context_length = context_length
        self.target_idx = target_idx
        
    def __len__(self):
        return len(self.data) - self.context_length
        
    def __getitem__(self, idx):
        x = self.data[idx : idx + self.context_length, :]
        y = self.data[idx + self.context_length, self.target_idx]
        return x, y

